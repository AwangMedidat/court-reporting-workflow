generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  NEW
  ASSIGNED
  TRANSCRIBED
  REVIEWED
  COMPLETED
}

model Reporter {
  id             String   @id @default(uuid())
  name           String
  location       String
  availability   Boolean  @default(true)
  ratePerMinute  Int      @default(2000)
  jobs           Job[]
}

model Editor {
  id            String   @id @default(uuid())
  name          String
  availability  Boolean  @default(true)
  flatFee       Int      @default(50000)
  jobs          Job[]
}

model Job {
  id         String    @id @default(uuid())
  caseName   String
  duration   Int
  location   String
  city       String
  status     JobStatus @default(NEW)
  reporterId String?
  editorId   String?
  reporter   Reporter? @relation(fields: [reporterId], references: [id])
  editor     Editor?   @relation(fields: [editorId], references: [id])
  createdAt  DateTime  @default(now())
}